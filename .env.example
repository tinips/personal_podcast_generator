# Copy to .env for Docker Compose, or to backend/.env for non-Docker backend runs.
# Keep real API keys out of committed files.
NEWS_API_KEY=
OPENAI_API_KEY=
ELEVENLABS_API_KEY=

# ElevenLabs voice IDs must belong to the same workspace/account as ELEVENLABS_API_KEY.
ELEVENLABS_VOICE_JOHN_CREATIVE=
ELEVENLABS_VOICE_MAYA_EDUCATIONAL=

# Frontend browser-facing API URL. Docker Compose uses this same default.
NEXT_PUBLIC_API_URL=http://localhost:8000

# Optional: two-voice dialogue audio assembly requires ffmpeg and ffprobe.
# Leave these commented when ffmpeg/ffprobe are available on PATH.
# FFMPEG_BINARY=C:\path\to\ffmpeg.exe
# FFPROBE_BINARY=C:\path\to\ffprobe.exe
